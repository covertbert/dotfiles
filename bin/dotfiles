#!/usr/bin/env bash

set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
	SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
	LINK_TARGET="$(readlink "$SCRIPT_SOURCE")"
	if [[ "$LINK_TARGET" == /* ]]; then
		SCRIPT_SOURCE="$LINK_TARGET"
	else
		SCRIPT_SOURCE="${SCRIPT_DIR}/${LINK_TARGET}"
	fi
done

DOTFILES_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")/.." && pwd)"
PI_AGENT_DIR="${PI_CODING_AGENT_DIR:-$HOME/.pi/agent}"
MCP_CONFIG_FILE="${MCP_CONFIG_FILE:-$HOME/.config/mcp/mcp.json}"
NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
NVM_DEFAULT_VERSION="${NVM_DEFAULT_VERSION:-24}"

# shellcheck source=../lib/manifest.sh
source "${DOTFILES_DIR}/lib/manifest.sh"
# shellcheck source=../lib/zsh-local-sync.sh
source "${DOTFILES_DIR}/lib/zsh-local-sync.sh"

# ── colours ──────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
	RED=$'\033[0;31m'
	GREEN=$'\033[0;32m'
	YELLOW=$'\033[0;33m'
	BLUE=$'\033[0;34m'
	BOLD=$'\033[1m'
	DIM=$'\033[2m'
	RESET=$'\033[0m'
else
	RED='' GREEN='' YELLOW='' BLUE='' BOLD='' DIM='' RESET=''
fi

info() { echo -e "${BLUE}==>${RESET} ${BOLD}$*${RESET}"; }
ok() { echo -e "${GREEN} ✓${RESET} $*"; }
warn() { echo -e "${YELLOW} !${RESET} $*"; }
err() { echo -e "${RED} ✗${RESET} $*" >&2; }
dim() { echo -e "${DIM}$*${RESET}"; }
heading() { echo -e "\n${BOLD}${BLUE}$*${RESET}"; }

# ── helpers ───────────────────────────────────────────────────────────────────
repo_path() { echo "${DOTFILES_DIR}/$1"; }

# Build a JSON array of keys from a CSV string (trimmed).
json_keys_array() {
	printf '%s' "$1" | jq -R 'split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(length > 0))'
}

# Emit JSON with the ignored top-level keys removed.
json_strip() {
	local file="$1" csv="$2"
	local keys
	keys="$(json_keys_array "$csv")"
	jq --argjson k "$keys" 'with_entries(select(.key as $x | $k | index($x) | not))' "$file"
}

# Emit JSON containing ONLY the ignored top-level keys (returns {} if file missing).
json_pick() {
	local file="$1" csv="$2"
	[[ -f "$file" ]] || { echo "{}"; return; }
	local keys
	keys="$(json_keys_array "$csv")"
	jq --argjson k "$keys" 'with_entries(select(.key as $x | $k | index($x)))' "$file"
}

items_differ() {
	local rp="$1" sp="$2" type="$3" ignore="${4:-}"
	local repo
	repo="$(repo_path "$rp")"

	if [[ "$type" == "dir" ]]; then
		[[ ! -d "$repo" ]] && return 1
		[[ ! -d "$sp" ]] && return 0
		diff -rq --exclude='*.sw*' --exclude='.DS_Store' "$repo" "$sp" &>/dev/null && return 1 || return 0
	elif [[ "$type" == "json-merge" ]]; then
		[[ ! -f "$repo" ]] && return 1
		[[ ! -f "$sp" ]] && return 0
		# Compare repo (canonical base) against system stripped of volatile keys.
		diff -q <(jq -S . "$repo") <(json_strip "$sp" "$ignore" | jq -S .) &>/dev/null && return 1 || return 0
	else
		[[ ! -f "$repo" ]] && return 1
		[[ ! -f "$sp" ]] && return 0
		diff -q "$repo" "$sp" &>/dev/null && return 1 || return 0
	fi
}

show_diff() {
	local rp="$1" sp="$2" type="$3" ignore="${4:-}"
	local repo
	repo="$(repo_path "$rp")"

	echo ""
	dim "  repo:   ${repo}"
	dim "  system: ${sp}"
	echo ""

	if [[ "$type" == "dir" ]]; then
		if [[ ! -d "$repo" ]]; then
			warn "  repo dir missing: ${repo}"
		elif [[ ! -d "$sp" ]]; then
			warn "  system dir missing (new on deploy): ${sp}"
		else
			diff --color=always -ruN --exclude='*.sw*' --exclude='.DS_Store' "$repo" "$sp" 2>/dev/null |
				grep -v 'No newline at end of file' |
				sed 's/^/  /' || true
		fi
	elif [[ "$type" == "json-merge" ]]; then
		if [[ ! -f "$repo" ]]; then
			warn "  repo file missing: ${repo}"
		elif [[ ! -f "$sp" ]]; then
			warn "  system file missing (new on deploy)"
		else
			dim "  (volatile keys ignored: ${ignore})"
			diff --color=always -u <(jq -S . "$repo") <(json_strip "$sp" "$ignore" | jq -S .) 2>/dev/null |
				tail -n +3 |
				grep -v 'No newline at end of file' |
				sed 's/^/  /' || true
		fi
	else
		if [[ ! -f "$repo" ]]; then
			warn "  repo file missing: ${repo}"
		elif [[ ! -f "$sp" ]]; then
			warn "  system file missing (new on deploy)"
		else
			diff --color=always -u "$repo" "$sp" 2>/dev/null |
				tail -n +3 |
				grep -v 'No newline at end of file' |
				sed 's/^/  /' || true
		fi
	fi
	echo ""
}

item_status() {
	local rp="$1" sp="$2" type="$3" ignore="${4:-}"
	local repo
	repo="$(repo_path "$rp")"

	if [[ "$type" == "dir" ]]; then
		[[ ! -d "$repo" ]] && echo "missing-repo" && return
		[[ ! -d "$sp" ]] && echo "missing-system" && return
	else
		[[ ! -f "$repo" ]] && echo "missing-repo" && return
		[[ ! -f "$sp" ]] && echo "missing-system" && return
	fi

	if items_differ "$rp" "$sp" "$type" "$ignore"; then
		echo "differ"
	else
		echo "in-sync"
	fi
}

# ── copy helpers ───────────────────────────────────────────────────────────────
copy_to_system() {
	local rp="$1" sp="$2" type="$3" ignore="${4:-}"
	local repo
	repo="$(repo_path "$rp")"

	if [[ "$type" == "dir" ]]; then
		if [[ ! -d "$repo" ]]; then
			warn "Skipping missing repo dir: ${repo}"
			return
		fi
		mkdir -p "$(dirname "$sp")"
		rm -rf -- "${sp:?}"
		cp -R "$repo" "$sp"
		ok "Deployed dir: ${sp}"
	elif [[ "$type" == "json-merge" ]]; then
		if [[ ! -f "$repo" ]]; then
			warn "Skipping missing repo file: ${repo}"
			return
		fi
		mkdir -p "$(dirname "$sp")"
		# Preserve system's volatile keys; overlay repo base on top.
		local volatile tmp
		volatile="$(json_pick "$sp" "$ignore")"
		tmp="${sp}.tmp.$"
		jq -s '.[0] * .[1]' "$repo" <(printf '%s' "$volatile") > "$tmp" && mv "$tmp" "$sp"
		ok "Merged: ${sp}"
	else
		if [[ ! -f "$repo" ]]; then
			warn "Skipping missing repo file: ${repo}"
			return
		fi
		mkdir -p "$(dirname "$sp")"
		cp "$repo" "$sp"
		ok "Deployed: ${sp}"
	fi
}

copy_to_repo() {
	local rp="$1" sp="$2" type="$3" ignore="${4:-}"
	local repo
	repo="$(repo_path "$rp")"

	if [[ "$type" == "dir" ]]; then
		if [[ ! -d "$sp" ]]; then
			warn "Skipping missing system dir: ${sp}"
			return
		fi
		# Safety guard: destination must be inside dotfiles dir
		if [[ "$repo" != "${DOTFILES_DIR}/"* ]]; then
			err "Refusing unsafe repo path: ${repo}"
			return 1
		fi
		mkdir -p "$(dirname "$repo")"
		rm -rf -- "${repo:?}"
		cp -R "$sp" "$repo"
		ok "Backfilled dir: ${repo}"
	elif [[ "$type" == "json-merge" ]]; then
		if [[ ! -f "$sp" ]]; then
			warn "Skipping missing system file: ${sp}"
			return
		fi
		if [[ "$repo" != "${DOTFILES_DIR}/"* ]]; then
			err "Refusing unsafe repo path: ${repo}"
			return 1
		fi
		mkdir -p "$(dirname "$repo")"
		# Strip volatile keys before writing into repo.
		json_strip "$sp" "$ignore" > "$repo"
		ok "Backfilled (stripped volatile): ${repo}"
	else
		if [[ ! -f "$sp" ]]; then
			warn "Skipping missing system file: ${sp}"
			return
		fi
		mkdir -p "$(dirname "$repo")"
		cp "$sp" "$repo"
		ok "Backfilled: ${repo}"
	fi
}

# ── prompt helpers ─────────────────────────────────────────────────────────────
read_user_input() {
	local __result_var="$1"
	local __reply=""

	if [[ -r /dev/tty ]]; then
		IFS= read -r __reply </dev/tty || return 1
	else
		IFS= read -r __reply || return 1
	fi

	printf -v "$__result_var" '%s' "$__reply"
}

read_user_key() {
	local __result_var="$1"
	local __reply=""

	if [[ -r /dev/tty ]]; then
		IFS= read -r -s -n 1 __reply </dev/tty || return 1
	else
		IFS= read -r -s -n 1 __reply || return 1
	fi

	printf -v "$__result_var" '%s' "$__reply"
}

confirm() {
	local prompt="$1"
	local reply=""
	echo -en "${YELLOW}${prompt}${RESET} [y/N] " >/dev/tty
	read_user_input reply || return 1
	[[ "$reply" =~ ^[Yy]$ ]]
}

ensure_nvm_default_node() {
	if [[ ! -s "${NVM_DIR}/nvm.sh" ]]; then
		err "NVM not found at ${NVM_DIR}/nvm.sh"
		return 1
	fi

	# shellcheck source=/dev/null
	source "${NVM_DIR}/nvm.sh"

	if ! command -v nvm &>/dev/null; then
		err "Failed to load nvm."
		return 1
	fi

	nvm install "${NVM_DEFAULT_VERSION}" >/dev/null
	nvm alias default "${NVM_DEFAULT_VERSION}" >/dev/null
	nvm use --silent "${NVM_DEFAULT_VERSION}" >/dev/null
}

# ── commands ───────────────────────────────────────────────────────────────────

cmd_status() {
	heading "Dotfiles status"

	local all_synced=true

	while IFS='|' read -r group type rp sp ignore; do
		local status
		status="$(item_status "$rp" "$sp" "$type" "$ignore")"
		case "$status" in
		in-sync)
			ok "${group}: ${rp}"
			;;
		differ)
			echo -e "${YELLOW} ~${RESET} ${group}: ${rp}  ${DIM}(differs)${RESET}"
			all_synced=false
			;;
		missing-repo)
			echo -e "${DIM} -${RESET} ${group}: ${rp}  ${DIM}(not in repo)${RESET}"
			;;
		missing-system)
			echo -e "${RED} +${RESET} ${group}: ${rp}  ${DIM}(not on system)${RESET}"
			all_synced=false
			;;
		esac
	done < <(
		dotfiles_manifest "$PI_AGENT_DIR" "$MCP_CONFIG_FILE" "$HOME"
		dotfiles_manifest_optional "$PI_AGENT_DIR"
	)

	echo ""
	if $all_synced; then
		ok "All managed files in sync."
	else
		warn "Some files differ. Run: dotfiles diff  or  dotfiles sync"
	fi
}

cmd_diff() {
	heading "Dotfiles diff"
	local found_any=false

	while IFS='|' read -r group type rp sp ignore; do
		local status
		status="$(item_status "$rp" "$sp" "$type" "$ignore")"
		if [[ "$status" == "in-sync" || "$status" == "missing-repo" ]]; then
			continue
		fi
		found_any=true
		echo -e "\n${BOLD}${group}: ${rp}${RESET}  ${DIM}[${status}]${RESET}"
		show_diff "$rp" "$sp" "$type" "$ignore"
	done < <(
		dotfiles_manifest "$PI_AGENT_DIR" "$MCP_CONFIG_FILE" "$HOME"
		dotfiles_manifest_optional "$PI_AGENT_DIR"
	)

	if ! $found_any; then
		ok "Nothing to diff — all managed files in sync."
	fi
}

cmd_sync() {
	local direction="${1:-}" # "", "system", or "repo"
	local yes_flag="${2:-}"  # "--yes" or ""

	heading "Dotfiles sync"

	local -a to_system_rp=()
	local -a to_system_sp=()
	local -a to_system_type=()
	local -a to_system_ignore=()
	local -a to_repo_rp=()
	local -a to_repo_sp=()
	local -a to_repo_type=()
	local -a to_repo_ignore=()

	while IFS='|' read -r group type rp sp ignore; do
		local status
		status="$(item_status "$rp" "$sp" "$type" "$ignore")"

		if [[ "$status" == "in-sync" ]]; then
			ok "${group}: ${rp}"
			continue
		fi

		if [[ "$status" == "missing-repo" ]]; then
			dim "  skip (not in repo): ${rp}"
			continue
		fi

		echo -e "\n${BOLD}${group}: ${rp}${RESET}  ${DIM}[${status}]${RESET}"
		show_diff "$rp" "$sp" "$type" "$ignore"

		if [[ -n "$direction" ]]; then
			# Non-interactive: queue based on direction
			if [[ "$direction" == "system" ]]; then
				to_system_rp+=("$rp")
				to_system_sp+=("$sp")
				to_system_type+=("$type")
				to_system_ignore+=("$ignore")
			else
				to_repo_rp+=("$rp")
				to_repo_sp+=("$sp")
				to_repo_type+=("$type")
				to_repo_ignore+=("$ignore")
			fi
		else
			# Interactive per-item prompt
			local choice=""
			while true; do
				echo -en "  ${YELLOW}Action?${RESET} ${BOLD}r${RESET}=repo→system  ${BOLD}s${RESET}=system→repo  ${BOLD}k${RESET}=skip  ${BOLD}q${RESET}=quit: " >/dev/tty
				read_user_key choice || {
					echo "" >/dev/tty
					err "Could not read input. Aborting."
					return 1
				}
				case "$choice" in
				r | R)
					echo "repo→system" >/dev/tty
					to_system_rp+=("$rp")
					to_system_sp+=("$sp")
					to_system_type+=("$type")
					to_system_ignore+=("$ignore")
					break
					;;
				s | S)
					echo "system→repo" >/dev/tty
					to_repo_rp+=("$rp")
					to_repo_sp+=("$sp")
					to_repo_type+=("$type")
					to_repo_ignore+=("$ignore")
					break
					;;
				k | K)
					echo "skip" >/dev/tty
					break
					;;
				q | Q)
					echo "quit" >/dev/tty
					echo "Aborted."
					return 1
					;;
				*)
					echo "" >/dev/tty
					echo "  Enter r, s, k, or q." >/dev/tty
					;;
				esac
			done
		fi
	done < <(
		dotfiles_manifest "$PI_AGENT_DIR" "$MCP_CONFIG_FILE" "$HOME"
		dotfiles_manifest_optional "$PI_AGENT_DIR"
	)

	# Summary and confirmation for non-interactive modes
	local total=$((${#to_system_rp[@]} + ${#to_repo_rp[@]}))
	if ((total == 0)); then
		echo ""
		ok "Nothing to sync."
		return
	fi

	if [[ -n "$direction" && "$yes_flag" != "--yes" ]]; then
		echo ""
		if ((${#to_system_rp[@]} > 0)); then
			info "${#to_system_rp[@]} file(s)/dir(s) → system"
		fi
		if ((${#to_repo_rp[@]} > 0)); then
			info "${#to_repo_rp[@]} file(s)/dir(s) → repo"
		fi
		confirm "Proceed?" || {
			echo "Aborted."
			return 1
		}
	fi

	# Execute queued writes
	for i in "${!to_system_rp[@]}"; do
		copy_to_system "${to_system_rp[$i]}" "${to_system_sp[$i]}" "${to_system_type[$i]}" "${to_system_ignore[$i]}"
	done
	for i in "${!to_repo_rp[@]}"; do
		copy_to_repo "${to_repo_rp[$i]}" "${to_repo_sp[$i]}" "${to_repo_type[$i]}" "${to_repo_ignore[$i]}"
	done

	echo ""
	ok "Sync complete."
}

cmd_brew() {
	local yes_flag="${1:-}"

	heading "Homebrew"
	echo ""

	local brewfile="${DOTFILES_DIR}/brew/Brewfile"
	local caskfile="${DOTFILES_DIR}/brew/Caskfile"

	info "Checking Brewfile (${brewfile})..."
	if brew bundle check --file="$brewfile" &>/dev/null; then
		ok "Brewfile satisfied."
	else
		warn "Brewfile has missing packages:"
		brew bundle check --file="$brewfile" --verbose 2>&1 | grep -v '^Using' | sed 's/^/  /' || true
	fi

	echo ""
	info "Checking Caskfile (${caskfile})..."
	if brew bundle check --file="$caskfile" &>/dev/null; then
		ok "Caskfile satisfied."
	else
		warn "Caskfile has missing casks:"
		brew bundle check --file="$caskfile" --verbose 2>&1 | grep -v '^Using' | sed 's/^/  /' || true
	fi

	echo ""
	if [[ "$yes_flag" != "--yes" ]]; then
		confirm "Run brew bundle for both files?" || {
			echo "Aborted."
			return 1
		}
	fi

	info "Running Brewfile..."
	if ! brew bundle --file="$brewfile"; then
		err "Brewfile install failed (see output above)."
		return 1
	fi
	ok "Brewfile done."

	echo ""
	info "Running Caskfile..."
	if ! brew bundle --file="$caskfile"; then
		err "Caskfile install failed (see output above)."
		return 1
	fi
	ok "Caskfile done."

	ok "Homebrew done."
}

cmd_brew_cleanup() {
	local yes_flag="${1:-}"

	heading "Homebrew cleanup"
	echo ""

	local brewfile="${DOTFILES_DIR}/brew/Brewfile"
	local caskfile="${DOTFILES_DIR}/brew/Caskfile"

	warn "This uninstalls Homebrew formulae and casks not listed in repo files."
	dim "  formulae source: ${brewfile}"
	dim "  casks source:    ${caskfile}"
	echo ""

	info "Formula cleanup preview..."
	brew bundle cleanup --file="$brewfile" --formula 2>&1 | sed 's/^/  /' || true

	echo ""
	info "Cask cleanup preview..."
	brew bundle cleanup --file="$caskfile" --cask 2>&1 | sed 's/^/  /' || true

	echo ""
	if [[ "$yes_flag" != "--yes" ]]; then
		confirm "Uninstall Homebrew packages not listed in brew files?" || {
			echo "Aborted."
			return 1
		}
	fi

	info "Cleaning formulae..."
	if ! brew bundle cleanup --file="$brewfile" --formula --force; then
		err "Formula cleanup failed (see output above)."
		return 1
	fi
	ok "Formula cleanup done."

	echo ""
	info "Cleaning casks..."
	if ! brew bundle cleanup --file="$caskfile" --cask --force; then
		err "Cask cleanup failed (see output above)."
		return 1
	fi
	ok "Cask cleanup done."

	ok "Homebrew cleanup done."
}

npm_package_name_from_spec() {
	local package_spec="$1"

	if [[ "$package_spec" == @* ]]; then
		if [[ "$package_spec" == @*/*@* ]]; then
			echo "${package_spec%@*}"
		else
			echo "$package_spec"
		fi
	elif [[ "$package_spec" == *@* ]]; then
		echo "${package_spec%%@*}"
	else
		echo "$package_spec"
	fi
}

npm_global_bin_names() {
	local package_json="$1"

	node -e '
const fs = require("node:fs");
const pkg = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
if (typeof pkg.bin === "string") {
  console.log(pkg.name.replace(/^@[^/]+\//, ""));
} else if (pkg.bin && typeof pkg.bin === "object") {
  for (const name of Object.keys(pkg.bin)) console.log(name);
}
' "$package_json"
}

npm_global_bins_are_healthy() {
	local package_spec="$1" current_prefix="$2"
	local package_name package_json bin_names bin_name
	package_name="$(npm_package_name_from_spec "$package_spec")"
	package_json="${current_prefix}/lib/node_modules/${package_name}/package.json"

	[[ -f "$package_json" ]] || return 1
	bin_names="$(npm_global_bin_names "$package_json")" || return 1

	while IFS= read -r bin_name; do
		[[ -z "$bin_name" ]] && continue
		[[ -x "${current_prefix}/bin/${bin_name}" ]] || return 1
	done <<< "$bin_names"
}

npm_other_nvm_installations() {
	local package_spec="$1" current_prefix="$2"
	local package_name current_version current_major version_dir version
	local found_versions=()
	package_name="$(npm_package_name_from_spec "$package_spec")"
	current_version="$(basename "$current_prefix")"
	current_major="${current_version%%.*}"

	for version_dir in "${NVM_DIR}"/versions/node/v*; do
		[[ -d "$version_dir" ]] || continue
		[[ "${version_dir%/}" == "${current_prefix%/}" ]] && continue
		[[ -f "${version_dir}/lib/node_modules/${package_name}/package.json" ]] || continue

		version="$(basename "$version_dir")"
		[[ "$version" == "${current_major}."* ]] || continue
		found_versions+=("$version")
	done

	if [[ ${#found_versions[@]} -eq 0 ]]; then
		return 1
	fi

	printf '%s\n' "${found_versions[@]}" |
		sort -t. -k1.2,1n -k2,2n -k3,3n |
		tail -n 3
}

cmd_npm() {
	local yes_flag="${1:-}"

	heading "npm globals"
	echo ""

	local globals_file="${DOTFILES_DIR}/npm/globals.txt"
	if [[ ! -f "$globals_file" ]]; then
		err "Globals file missing: ${globals_file}"
		return 1
	fi

	ensure_nvm_default_node || return 1

	local packages=()
	while IFS= read -r line; do
		[[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
		packages+=("$line")
	done < "$globals_file"

	if [[ ${#packages[@]} -eq 0 ]]; then
		warn "No npm globals listed in ${globals_file}."
		return 0
	fi

	local current_node current_prefix old_installations
	local missing=()
	local pkg
	local found_old_nvm_install=false
	current_node="$(node --version)"
	current_prefix="$(npm prefix -g)"

	for pkg in "${packages[@]}"; do
		if npm -g ls --depth=0 "$pkg" &>/dev/null; then
			if npm_global_bins_are_healthy "$pkg" "$current_prefix"; then
				ok "Installed under Node ${current_node}: ${pkg}"
				continue
			fi

			warn "Broken under Node ${current_node}: ${pkg} (global bin missing)"
		else
			warn "Missing under Node ${current_node}: ${pkg}"
		fi

		missing+=("$pkg")

		if old_installations="$(npm_other_nvm_installations "$pkg" "$current_prefix")"; then
			while IFS= read -r old_version; do
				dim "    found under old Node ${old_version}"
			done <<< "$old_installations"
			found_old_nvm_install=true
		fi
	done

	if $found_old_nvm_install; then
		echo ""
		warn "Old NVM package copies were left untouched."
		dim "  Inspect runtimes: nvm ls"
		dim "  After verifying no project needs one: nvm uninstall <version>"
	fi

	echo ""
	if [[ ${#missing[@]} -eq 0 ]]; then
		ok "npm globals satisfied."
		return 0
	fi

	if [[ "$yes_flag" != "--yes" ]]; then
		confirm "Install missing npm globals?" || {
			echo "Aborted."
			return 1
		}
	fi

	info "Installing missing npm globals under Node ${current_node}..."
	if ! npm install -g --ignore-scripts "${missing[@]}"; then
		err "npm global install failed (see output above)."
		return 1
	fi

	local install_failed=false
	for pkg in "${missing[@]}"; do
		if npm -g ls --depth=0 "$pkg" &>/dev/null && npm_global_bins_are_healthy "$pkg" "$current_prefix"; then
			ok "Ready under Node ${current_node}: ${pkg}"
		else
			err "Package installed without expected global bin: ${pkg}"
			install_failed=true
		fi
	done

	if $install_failed; then
		return 1
	fi

	ok "npm globals done."
}

load_nvm_runtime() {
	if [[ ! -s "${NVM_DIR}/nvm.sh" ]]; then
		err "NVM not found at ${NVM_DIR}/nvm.sh"
		return 1
	fi

	# NVM is not nounset-safe while loading.
	set +u
	# shellcheck source=/dev/null
	local source_status=0
	source "${NVM_DIR}/nvm.sh" || source_status=$?
	set -u

	if ((source_status != 0)) || ! command -v nvm &>/dev/null; then
		err "Failed to load NVM."
		return 1
	fi
}

pi_meridian_node_bin_dir() {
	load_nvm_runtime >/dev/null || return 1

	local node_bin
	if ! node_bin="$(nvm which default 2>/dev/null)" || [[ ! -x "$node_bin" ]]; then
		err "Default NVM Node not found. Run: dotfiles npm"
		return 1
	fi

	dirname "$node_bin"
}

pi_meridian_wait_for_health() {
	local url="$1" attempts="$2"
	local attempt

	for ((attempt = 1; attempt <= attempts; attempt++)); do
		if curl -fsS --max-time 2 "$url" >/dev/null 2>&1; then
			return 0
		fi
		sleep 1
	done

	return 1
}

pi_meridian_show_health() {
	local label="$1" url="$2"
	local body status

	if ! body="$(curl -fsS --max-time 2 "$url" 2>/dev/null)"; then
		warn "${label}: unavailable (${url})"
		return 1
	fi

	if command -v jq &>/dev/null; then
		status="$(printf '%s' "$body" | jq -r '.status // "responding"' 2>/dev/null || echo "responding")"
	else
		status="responding"
	fi

	ok "${label}: ${status} (${url})"
}

pi_meridian_check_dependencies() {
	local node_bin_dir node_major
	local dependency

	for dependency in curl launchctl plutil; do
		if ! command -v "$dependency" &>/dev/null; then
			err "Missing dependency: ${dependency}"
			return 1
		fi
	done

	if ! PATH="/opt/homebrew/bin:/usr/local/bin:$PATH" command -v claude &>/dev/null; then
		err "Claude Code not found. Run: dotfiles brew"
		return 1
	fi

	node_bin_dir="$(pi_meridian_node_bin_dir)" || return 1
	node_major="$("${node_bin_dir}/node" -p 'process.versions.node.split(".")[0]')"

	if ((node_major < 22)); then
		err "Meridian requires Node 22 or newer; default NVM Node is $("${node_bin_dir}/node" --version)."
		return 1
	fi

	for dependency in meridian pi; do
		if [[ ! -x "${node_bin_dir}/${dependency}" ]]; then
			err "${dependency} not installed under default NVM Node. Run: dotfiles npm"
			return 1
		fi
	done
}

cmd_pi_meridian_setup() {
	local yes_flag="${1:-}"
	local label="com.bertie.pi-meridian-stack"
	local uid domain target plist

	heading "Pi → Meridian setup"
	echo ""

	if [[ "$(uname -s)" != "Darwin" ]]; then
		err "Pi → Meridian launchd service requires macOS."
		return 1
	fi

	pi_meridian_check_dependencies || return 1

	if [[ "$yes_flag" != "--yes" ]]; then
		warn "This deploys service files and reloads the launchd agent."
		confirm "Set up Pi → Meridian service?" || {
			echo "Aborted."
			return 1
		}
	fi

	copy_to_system \
		"services/pi-meridian/pi-meridian-proxy.mjs" \
		"${HOME}/.local/bin/pi-meridian-proxy.mjs" \
		"file"
	copy_to_system \
		"services/pi-meridian/pi-meridian-stack.sh" \
		"${HOME}/.local/bin/pi-meridian-stack.sh" \
		"file"
	copy_to_system \
		"services/pi-meridian/com.bertie.pi-meridian-stack.plist" \
		"${HOME}/Library/LaunchAgents/${label}.plist" \
		"file"

	chmod +x \
		"${HOME}/.local/bin/pi-meridian-proxy.mjs" \
		"${HOME}/.local/bin/pi-meridian-stack.sh"
	mkdir -p "${HOME}/Library/Logs/pi-meridian"

	plist="${HOME}/Library/LaunchAgents/${label}.plist"
	if ! plutil -lint "$plist"; then
		err "Invalid launchd plist: ${plist}"
		return 1
	fi

	uid="$(id -u)"
	domain="gui/${uid}"
	target="${domain}/${label}"

	if launchctl print "$target" &>/dev/null; then
		info "Unloading existing launchd service..."
		if ! launchctl bootout "$target"; then
			launchctl bootout "$domain" "$plist"
		fi
	fi

	launchctl enable "$target"
	launchctl bootstrap "$domain" "$plist"
	launchctl kickstart -k "$target"
	ok "Launchd service loaded: ${label}"

	if pi_meridian_wait_for_health "http://127.0.0.1:3456/health" 30; then
		ok "Meridian responding on 127.0.0.1:3456"
	else
		warn "Meridian health check failed. Run: dotfiles pi-meridian logs"
	fi

	if pi_meridian_wait_for_health "http://127.0.0.1:3457/health" 15; then
		ok "Rewrite proxy responding on 127.0.0.1:3457"
	else
		warn "Rewrite proxy health check failed. Run: dotfiles pi-meridian logs"
	fi

	if PATH="/opt/homebrew/bin:/usr/local/bin:$PATH" claude auth status &>/dev/null; then
		ok "Claude Code authenticated."
	else
		warn "Claude Code not authenticated. Run: claude login"
		warn "Then restart stack: dotfiles pi-meridian restart"
	fi
}

cmd_pi_meridian_status() {
	local label="com.bertie.pi-meridian-stack"
	local target
	local node_bin_dir=""
	local service_state=""
	target="gui/$(id -u)/${label}"

	heading "Pi → Meridian status"
	echo ""

	if launchctl print "$target" &>/dev/null; then
		service_state="$(launchctl print "$target" 2>/dev/null | awk '/^[[:space:]]*state = / { print $3; exit }')"
		ok "Launchd: ${service_state:-loaded} (${label})"
	else
		warn "Launchd: not loaded. Run: dotfiles pi-meridian setup"
	fi

	pi_meridian_show_health "Meridian" "http://127.0.0.1:3456/health" || true
	pi_meridian_show_health "Rewrite proxy" "http://127.0.0.1:3457/health" || true

	if node_bin_dir="$(pi_meridian_node_bin_dir 2>/dev/null)"; then
		if [[ -x "${node_bin_dir}/meridian" ]]; then
			ok "Meridian CLI: $("${node_bin_dir}/meridian" --version 2>/dev/null)"
		else
			warn "Meridian CLI missing under default NVM Node."
		fi
	else
		warn "Default NVM Node unavailable."
	fi

	if PATH="/opt/homebrew/bin:/usr/local/bin:$PATH" command -v claude &>/dev/null; then
		if PATH="/opt/homebrew/bin:/usr/local/bin:$PATH" claude auth status &>/dev/null; then
			ok "Claude Code: authenticated"
		else
			warn "Claude Code: not authenticated. Run: claude login"
		fi
	else
		warn "Claude Code: not installed. Run: dotfiles brew"
	fi
}

cmd_pi_meridian_restart() {
	local label="com.bertie.pi-meridian-stack"
	local domain target
	local plist="${HOME}/Library/LaunchAgents/${label}.plist"
	domain="gui/$(id -u)"
	target="${domain}/${label}"

	heading "Pi → Meridian restart"

	if [[ ! -f "$plist" ]]; then
		err "Launch agent missing: ${plist}"
		err "Run: dotfiles pi-meridian setup"
		return 1
	fi

	plutil -lint "$plist" >/dev/null
	launchctl enable "$target"

	if launchctl print "$target" &>/dev/null; then
		launchctl kickstart -k "$target"
	else
		launchctl bootstrap "$domain" "$plist"
		launchctl kickstart -k "$target"
	fi

	ok "Restarted: ${label}"
}

cmd_pi_meridian_stop() {
	local label="com.bertie.pi-meridian-stack"
	local target
	target="gui/$(id -u)/${label}"

	heading "Pi → Meridian stop"

	launchctl disable "$target"
	if launchctl print "$target" &>/dev/null; then
		launchctl bootout "$target"
		ok "Stopped and unloaded: ${label}"
	else
		ok "Already stopped: ${label}"
	fi
}

cmd_pi_meridian_logs() {
	local log_dir="${HOME}/Library/Logs/pi-meridian"
	local log_file

	heading "Pi → Meridian logs"

	for log_file in stack.log meridian.log proxy.log; do
		echo ""
		echo -e "${BOLD}${log_file}${RESET}"
		if [[ -f "${log_dir}/${log_file}" ]]; then
			tail -n 100 "${log_dir}/${log_file}"
		else
			dim "  No log file at ${log_dir}/${log_file}"
		fi
	done
}

cmd_pi_meridian() {
	local action="${1:-status}"
	local yes_flag="${2:-}"

	case "$action" in
	setup) cmd_pi_meridian_setup "$yes_flag" ;;
	status) cmd_pi_meridian_status ;;
	restart) cmd_pi_meridian_restart ;;
	stop) cmd_pi_meridian_stop ;;
	logs) cmd_pi_meridian_logs ;;
	*)
		err "Unknown pi-meridian action: ${action}"
		echo "Usage: dotfiles pi-meridian {setup|status|restart|stop|logs} [--yes]"
		return 1
		;;
	esac
}

cmd_defaults() {
	local yes_flag="${1:-}"

	heading "macOS defaults"
	echo ""

	local defaults_dir="${DOTFILES_DIR}/defaults"
	warn "This will apply broad macOS system preferences and restart Dock/Finder."
	echo "  Scripts to run:"
	for script in system.sh chrome.sh transmission.sh; do
		dim "    ${defaults_dir}/${script}"
	done

	echo ""
	if [[ "$yes_flag" != "--yes" ]]; then
		confirm "Apply macOS defaults?" || {
			echo "Aborted."
			return 1
		}
	fi

	for script in system.sh chrome.sh transmission.sh; do
		info "Applying ${script}..."
		bash "${defaults_dir}/${script}"
	done

	ok "Defaults applied."
}

cmd_check() {
	heading "Shell validation"
	local failed=false

	while IFS= read -r -d '' f; do
		if ! bash -n "$f" 2>/dev/null; then
			err "Syntax error: ${f}"
			failed=true
		fi
		if ! shfmt -d "$f" &>/dev/null; then
			warn "shfmt: ${f}"
			failed=true
		fi
		if ! shellcheck -S warning "$f" &>/dev/null; then
			warn "shellcheck: ${f}"
			failed=true
		fi
	done < <(find "$DOTFILES_DIR" -name '*.sh' -not -path '*/.git/*' -print0)

	# Also check bin/dotfiles and lib/*.sh
	for extra in "${BASH_SOURCE[0]}" "${DOTFILES_DIR}/lib/"*.sh; do
		[[ -f "$extra" ]] || continue
		if ! bash -n "$extra" 2>/dev/null; then
			err "Syntax error: ${extra}"
			failed=true
		fi
		if ! shellcheck -S warning "$extra" &>/dev/null; then
			warn "shellcheck: ${extra}"
			failed=true
		fi
	done

	local node_bin_dir=""
	local node_command=""
	if node_bin_dir="$(pi_meridian_node_bin_dir 2>/dev/null)"; then
		node_command="${node_bin_dir}/node"
	elif command -v node &>/dev/null; then
		node_command="$(command -v node)"
	fi

	if [[ -z "$node_command" ]]; then
		warn "Node unavailable: cannot validate Pi → Meridian proxy"
		failed=true
	else
		while IFS= read -r -d '' f; do
			if ! "$node_command" --check "$f" &>/dev/null; then
				warn "node --check: ${f}"
				failed=true
			fi
		done < <(find "${DOTFILES_DIR}/services/pi-meridian" -name '*.mjs' -print0)

		if ! "$node_command" --test "${DOTFILES_DIR}/services/pi-meridian/pi-meridian-proxy.test.mjs"; then
			warn "node --test: Pi → Meridian proxy"
			failed=true
		fi
	fi

	while IFS= read -r -d '' f; do
		if ! plutil -lint "$f" &>/dev/null; then
			warn "plutil: ${f}"
			failed=true
		fi
	done < <(find "${DOTFILES_DIR}/services/pi-meridian" -name '*.plist' -print0)

	if ! bash "${DOTFILES_DIR}/tests/zsh-local-sync.test.sh"; then
		warn "tests: zsh-local sync"
		failed=true
	fi

	if $failed; then
		err "Validation failed."
		return 1
	else
		ok "All checks passed."
	fi
}

cmd_install() {
	heading "Install dotfiles command"

	local target="${HOME}/.local/bin/dotfiles"
	local this="${DOTFILES_DIR}/bin/dotfiles"

	mkdir -p "${HOME}/.local/bin"

	if [[ -L "$target" ]] && [[ "$(readlink "$target")" == "$this" ]]; then
		ok "Already installed: ${target} -> ${this}"
		return
	fi

	ln -sf "$this" "$target"
	chmod +x "$this"
	ok "Installed: ${target} -> ${this}"
	dim "  Make sure \$HOME/.local/bin is on your PATH (it is in config/zsh/.zshrc)."
}

cmd_installers() {
	local yes_flag="${1:-}"

	heading "Install dependencies (NVM, zgen)"
	echo ""

	# NVM
	if command -v nvm &>/dev/null || [[ -s "${NVM_DIR}/nvm.sh" ]]; then
		ok "NVM already installed."
	else
		if [[ "$yes_flag" != "--yes" ]]; then
			confirm "Install NVM?" || true
		fi
		echo "Installing NVM..."
		curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.3/install.sh | bash
	fi

	# zgen
	local zgen_dir="${HOME}/.zgen"
	if [[ -d "$zgen_dir" ]]; then
		ok "zgen already installed."
	else
		if [[ "$yes_flag" != "--yes" ]]; then
			confirm "Install zgen?" || true
		fi
		git clone https://github.com/tarjoilija/zgen.git "$zgen_dir"
		ok "zgen installed."
	fi
}

# ── usage ──────────────────────────────────────────────────────────────────────
usage() {
	cat <<EOF
${BOLD}dotfiles${RESET} — manage and sync your dotfiles

${BOLD}USAGE${RESET}
  dotfiles <command> [options]

${BOLD}COMMANDS${RESET}
  status              Show which managed files differ between repo and system
  diff                Show detailed diffs for all changed files
  sync                Interactive per-item sync (prompts repo→system or system→repo per diff)
  sync --to system    Deploy all changes from repo to system
  sync --to repo      Backfill all changes from system to repo
  brew                Preview and run Homebrew bundle install
  brew-cleanup        Uninstall Homebrew packages not listed in brew files
  npm                 Check and install managed npm globals
  zsh-local <action>  Back up and restore ~/.zshrc.local with 1Password
  pi-meridian <action> Manage Pi → Meridian launchd service
  defaults            Preview and apply macOS system defaults
  check               Validate shell, proxy, tests, and launchd plist
  install             Create ~/.local/bin/dotfiles symlink
  installers          Install NVM and zgen if missing

${BOLD}FLAGS${RESET}
  --yes               Skip confirmation prompts (including explicit zsh-local overwrites)

${BOLD}ALIASES${RESET}
  deploy              Alias for: sync --to system
  backfill            Alias for: sync --to repo

${BOLD}EXAMPLES${RESET}
  dotfiles status
  dotfiles diff
  dotfiles sync
  dotfiles sync --to system --yes
  dotfiles sync --to repo
  dotfiles brew
  dotfiles brew-cleanup
  dotfiles npm
  dotfiles zsh-local setup
  dotfiles zsh-local edit
  dotfiles pi-meridian setup
  dotfiles pi-meridian status
  dotfiles defaults --yes
  dotfiles deploy
  dotfiles backfill
EOF
}

# ── dispatch ───────────────────────────────────────────────────────────────────
main() {
	local cmd="${1:-help}"
	shift || true

	local direction=""
	local yes_flag=""

	# Parse remaining flags
	local positional=()
	while (($# > 0)); do
		case "$1" in
		--to)
			direction="${2:-}"
			shift 2
			;;
		--yes)
			yes_flag="--yes"
			shift
			;;
		*)
			positional+=("$1")
			shift
			;;
		esac
	done

	case "$cmd" in
	status) cmd_status ;;
	diff) cmd_diff ;;
	sync) cmd_sync "$direction" "$yes_flag" ;;
	deploy) cmd_sync "system" "$yes_flag" ;;
	backfill) cmd_sync "repo" "$yes_flag" ;;
	brew) cmd_brew "$yes_flag" ;;
	brew-cleanup) cmd_brew_cleanup "$yes_flag" ;;
	npm) cmd_npm "$yes_flag" ;;
	zsh-local) cmd_zsh_local "$yes_flag" "${positional[@]}" ;;
	pi-meridian) cmd_pi_meridian "${positional[0]:-status}" "$yes_flag" ;;
	defaults) cmd_defaults "$yes_flag" ;;
	check) cmd_check ;;
	install) cmd_install ;;
	installers) cmd_installers "$yes_flag" ;;
	help | --help | -h) usage ;;
	*)
		err "Unknown command: ${cmd}"
		echo ""
		usage
		exit 1
		;;
	esac
}

main "$@"
